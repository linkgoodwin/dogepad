# ============================================
# DogePad 环境配置（示例文件）
# 复制为 .env 后填写实际值
# ============================================

# --- 钱包连接 ---
# WalletConnect 项目ID，用于手机钱包扫码连接
# 获取方式：https://cloud.walletconnect.com/ 注册免费项目
# 不填也可以用，但扫码连接功能不可用，MetaMask 浏览器插件连接不受影响
VITE_WALLETCONNECT_PROJECT_ID=

# --- 网络选择 ---
# 当前默认网络：97 = BSC测试网，56 = BSC主网
# 切换主网只需改这一个数字，然后重启开发服务器
VITE_CHAIN_ID=97

# --- 前端 RPC 节点 ---
# 前端通过这些节点读取链上数据（余额、合约状态等）
# 免费公共节点有速率限制，生产环境建议用付费节点（如 QuickNode、GetBlock、Ankr）
VITE_BSC_TESTNET_RPC=https://bsc-testnet.publicnode.com
VITE_BSC_MAINNET_RPC=https://bsc.publicnode.com

# --- IPFS 图片存储（Pinata）---
# Pinata JWT 用于上传代币头像到 IPFS
# 获取方式：https://app.pinata.cloud/ 注册 → API Keys → New Key → 复制 JWT
# 免费额度：1GB 存储，足够约 5000 张 200KB 图片
# 不填则图片上传功能不可用，但其他功能正常
VITE_PINATA_JWT=

# ============================================
# 合约地址（部署脚本自动写入，无需手动填写）
# 测试网和主网地址分开存储，互不影响
# ============================================

# --- BSC 测试网合约地址 ---
# 部署命令: .\scripts\deploy-contracts.ps1 -Network bscTestnet
VITE_TESTNET_BONDING_CURVE_ADDRESS=
VITE_TESTNET_FACTORY_ADDRESS=
VITE_TESTNET_LONG_POOL_ADDRESS=
VITE_TESTNET_SHORT_POOL_ADDRESS=
VITE_TESTNET_BUY_AND_BURN_ADDRESS=
VITE_TESTNET_LAUNCH_DAO_ADDRESS=
VITE_TESTNET_PRICE_ORACLE_ADDRESS=
VITE_TESTNET_FEE_DISTRIBUTOR_ADDRESS=
VITE_TESTNET_CREATOR_REWARD_MANAGER_ADDRESS=
VITE_TESTNET_EXP_RATE_MODEL_ADDRESS=
VITE_TESTNET_LIN_RATE_MODEL_ADDRESS=

# --- BSC 主网合约地址 ---
# 部署命令: .\scripts\deploy-contracts.ps1 -Network bscMainnet
VITE_MAINNET_BONDING_CURVE_ADDRESS=
VITE_MAINNET_FACTORY_ADDRESS=
VITE_MAINNET_LONG_POOL_ADDRESS=
VITE_MAINNET_SHORT_POOL_ADDRESS=
VITE_MAINNET_BUY_AND_BURN_ADDRESS=
VITE_MAINNET_LAUNCH_DAO_ADDRESS=
VITE_MAINNET_PRICE_ORACLE_ADDRESS=
VITE_MAINNET_FEE_DISTRIBUTOR_ADDRESS=
VITE_MAINNET_CREATOR_REWARD_MANAGER_ADDRESS=
VITE_MAINNET_EXP_RATE_MODEL_ADDRESS=
VITE_MAINNET_LIN_RATE_MODEL_ADDRESS=

# --- 部署者私钥（可选，不填则部署时手动输入）---
# 如果填了，部署脚本会自动使用；如果不填，每次部署时会提示你输入
# 私钥只在内存中存在，不会保存到文件
# 注意：绝不能提交到 Git 或泄露给任何人！
# DEPLOYER_PRIVATE_KEY=

# --- BSCScan API Key ---
# 用于在 BSCScan 上验证合约源码，让合约代码公开可读
# 获取方式：https://bscscan.com/register 注册后在 API Keys 页面创建
# 不填不影响合约运行，只是合约在 BSCScan 上显示为未验证（看不到源码）
BSCSCAN_API_KEY=

# --- 部署用 RPC 节点 ---
# Hardhat 部署合约时使用，与前端 RPC 分开（避免前端节点限流影响部署）
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/
